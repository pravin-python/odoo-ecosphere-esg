DJANGO_SETTINGS_MODULE=config.settings.development

SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL is required (row-level security). Connect as a NON-superuser,
# NOBYPASSRLS role so policies are enforced — see scripts/db/init.sql.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ecosphere
DB_USER=ecosphere_app
DB_PASSWORD=ecosphere
DB_HOST=localhost
DB_PORT=5432
CONN_MAX_AGE=60

CORS_ALLOWED_ORIGINS=

SECURE_SSL_REDIRECT=False

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
